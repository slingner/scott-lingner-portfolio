---
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import ProjectCard from "@components/ProjectCard.astro";
import BackToPrevious from "@components/BackToPrevious.astro";
import ExperienceHero from "@components/ExperienceHero.astro";
import { getCollection } from "astro:content";

const allProjects = await getCollection("projects");
const prendaProjects = allProjects
  .filter((p) => !p.data.draft && p.slug.startsWith("prenda-"))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const prendaImages: Record<string, { image: string; imagePosition?: string }> = {
  "prenda-create-projects": { image: "/create.png", imagePosition: "center 25%" },
  "prenda-memory-challenge": { image: "/memory-challenge-math.png", imagePosition: "center" },
  "prenda-background-checks": { image: "/checkr-background-checks.png", imagePosition: "center 15%" },
  "prenda-portfolio": { image: "/portfolio.png", imagePosition: "center" },
};

const skills = [
  "React",
  "TypeScript",
  "Next.js",
  "Node.js",
  "Tailwind",
  "MongoDB",
  "GraphQL",
];
---

<Layout
  title="Frontend Engineer — Prenda"
  description="Scott Lingner's work as a Frontend Engineer at Prenda, an EdTech platform serving thousands of students."
>
  <Container>
    <div class="animate mt-8">
      <BackToPrevious href="/">Home</BackToPrevious>
    </div>

    <div class="animate my-10">
      <ExperienceHero
        company="Prenda"
        role="Frontend Engineer"
        period="Aug 2020 – Sep 2024"
        accent="prenda"
        siteLabel="prenda.com"
        siteHref="https://prenda.com"
        description="Developed and styled educational interactive web apps for an EdTech platform serving thousands of students across hundreds of microschools. Collaborated closely with UI/UX and curriculum teams to ship new features and optimize user experience from onboarding through daily student use."
        skills={skills}
        image="/prenda.png"
        imagePosition="right"
      />
    </div>

    <div class="animate">
      <h2
        class="mb-6 text-xl font-semibold text-stone-900 dark:text-stone-100"
      >
        Projects
      </h2>
      <ul class="not-prose flex flex-col gap-4">
        {
          prendaProjects.map((project) => (
            <li>
              <ProjectCard entry={project} {...prendaImages[project.slug]} />
            </li>
          ))
        }
      </ul>
    </div>
  </Container>
</Layout>
