---
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import BackToPrevious from "@components/BackToPrevious.astro";
import ExperienceHero from "@components/ExperienceHero.astro";

const skills = ["AI/ML", "Data Analysis", "Quality Assurance", "Photography"];
---

<Layout
  title="Photography Consultant for Google AI — Filter"
  description="Scott Lingner's consulting work on AI training data and quality assurance for Google's machine learning initiatives."
>
  <Container>
    <div class="animate mt-8">
      <BackToPrevious href="/">Home</BackToPrevious>
    </div>

    <div class="animate my-10">
      <ExperienceHero
        company="Google AI"
        role="Photography Consultant — Filter, A Merkle Company"
        period="Feb 2017 – May 2020"
        accent="google"
        siteLabel="Google Research post"
        siteHref="https://research.google/blog/using-deep-learning-to-create-professional-level-photographs/"
        description="Provided photography domain expertise to support Google's AI training data initiatives. This work involved evaluating image quality, identifying aesthetic and technical attributes, and contributing to quality assurance pipelines used to train deep learning models for computational photography — work that fed into research on professional-level image generation."
        skills={skills}
        image="/google-ai-2.png"
        imagePosition="center 30%"
      />
    </div>

    <div class="animate mb-10 space-y-4">
      <h2 class="text-xl font-semibold text-stone-900 dark:text-stone-100">
        What I worked on
      </h2>
      <p class="text-base leading-relaxed text-stone-600 dark:text-stone-400">
        Through Filter, a Merkle company, I brought photography expertise to
        Google's work on computational photography — evaluating image quality
        and identifying the aesthetic and technical attributes that separate
        a professional photograph from an amateur one. That domain knowledge
        fed into quality assurance pipelines for the training data used to
        develop deep learning models.
      </p>
      <p class="text-base leading-relaxed text-stone-600 dark:text-stone-400">
        The research this work supported was later published by Google
        Research: <a
          href="https://research.google/blog/using-deep-learning-to-create-professional-level-photographs/"
          target="_blank"
          rel="noopener noreferrer"
          class="underline decoration-stone-500/40 underline-offset-2 hover:decoration-stone-700 dark:hover:decoration-stone-300"
          >Using Deep Learning to Create Professional-Level Photographs</a
        >, which describes a system trained to generate photographs judged
        comparable in quality to a professional's.
      </p>
    </div>
  </Container>
</Layout>
