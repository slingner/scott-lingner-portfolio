---
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import BackToPrevious from "@components/BackToPrevious.astro";
import ExperienceHero from "@components/ExperienceHero.astro";

const skills = ["React", "JavaScript", "TypeScript", "Figma", "CSS", "HTML"];
---

<Layout
  title="Frontend Engineer Intern — untitled.stream"
  description="Scott Lingner's internship as a Frontend Engineer at untitled.stream, a live streaming platform."
>
  <Container>
    <div class="animate mt-8">
      <BackToPrevious href="/">Home</BackToPrevious>
    </div>

    <div class="animate my-10">
      <ExperienceHero
        company="untitled.stream"
        role="Frontend Engineer Intern"
        period="Jun 2020 – Aug 2020"
        accent="stream"
        siteLabel="untitled.stream"
        siteHref="https://untitled.stream"
        description="Built a multi-layered React desktop app that expanded mobile features and improved the user experience of a live streaming platform. Worked closely with the design team, producing UX/UI mockups in Figma that guided development and ensured a cohesive, usable interface."
        skills={skills}
        image="/untitled-steam.png"
        imagePosition="center 45%"
      />
    </div>

    <div class="animate mb-10 space-y-4">
      <h2 class="text-xl font-semibold text-stone-900 dark:text-stone-100">
        What I worked on
      </h2>
      <p class="text-base leading-relaxed text-stone-600 dark:text-stone-400">
        untitled.stream is a live streaming platform, and my work centered on
        its desktop app — a multi-layered React interface that needed to carry
        over feature parity from mobile while adapting to a larger,
        multi-pane layout. I worked closely with the design team throughout,
        turning UX/UI mockups from Figma into working React components and
        flagging usability issues before they shipped.
      </p>
      <p class="text-base leading-relaxed text-stone-600 dark:text-stone-400">
        The internship was a first introduction to working inside an
        established design system rather than building one from scratch —
        matching an existing visual language in CSS and HTML while expanding
        the product's feature set for a new platform.
      </p>
    </div>
  </Container>
</Layout>
