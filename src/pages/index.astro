---
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import Pelican from "@components/Pelican.astro";
import ExperienceCard from "@components/ExperienceCard.astro";
import { SITE, HOME, SOCIALS } from "@consts";
import Link from "@components/Link.astro";

const projects = [
  {
    company: "Swatch Mill",
    role: "Adobe Illustrator Plugin",
    period: "Sep 2024 – Present",
    description:
      "A commercial Illustrator plugin for fashion brands that automates color palette extraction and matching from garment and brand references.",
    skills: ["TypeScript", "React", "Next.js", "Astro", "Sanity", "Node.js"],
    url: "/projects/swatchmill",
    accent: "independent",
    image: "/swatch-mill.png",
    imagePosition: "center 20%",
  },
  {
    company: "Rocket Boogie Co",
    role: "Custom E-Commerce Platform",
    period: "2014 – Present",
    description:
      "A design studio making whimsical art and lifestyle goods, with a fully custom e-commerce platform I built from scratch on Next.js and Supabase.",
    skills: ["Next.js", "Supabase", "Stripe", "Tailwind CSS", "Vercel"],
    url: "/projects/rocket-boogie",
    accent: "rocket",
    image: "/rbc.png",
    imagePosition: "center 30%",
  },
];

const jobs = [
  {
    company: "Handshake AI",
    role: "AI Trainer — Software + 2D Graphics Expert",
    period: "May 2026 – Present",
    description:
      "Improving LLM reliability in software engineering and 2D graphics through adversarial prompt design and rubric-based evaluation.",
    skills: ["LLM Evaluation", "Prompt Engineering", "Software Engineering", "2D Graphics"],
    url: "/software-engineering/handshake-ai",
    accent: "handshake",
    image: "/handshake.jpg",
    imagePosition: "center",
  },
  {
    company: "Prenda",
    role: "Frontend Engineer",
    period: "Aug 2020 – Sep 2024",
    description:
      "Educational web apps for an EdTech platform serving thousands of students across hundreds of microschools.",
    skills: ["React", "TypeScript", "Next.js", "Node.js", "Tailwind", "MongoDB"],
    url: "/software-engineering/prenda",
    accent: "prenda",
    image: "/prenda.png",
    imagePosition: "right",
  },
  {
    company: "untitled.stream",
    role: "Frontend Engineer Intern",
    period: "Jun 2020 – Aug 2020",
    description:
      "A multi-layered React desktop app expanding mobile features, built from UX/UI designs in Figma.",
    skills: ["React", "JavaScript", "Figma", "CSS"],
    url: "/software-engineering/untitled-stream",
    accent: "stream",
    image: "/untitled-steam.png",
    imagePosition: "center 45%",
  },
  {
    company: "Google AI",
    role: "Photography Consultant",
    period: "Feb 2017 – May 2020",
    description:
      "Photography domain expertise for Google's AI training data, contributing to QA pipelines for computational photography models.",
    skills: ["AI/ML", "Data Analysis", "Photography"],
    url: "/software-engineering/google-ai",
    accent: "google",
    image: "/google-ai.png",
    imagePosition: "80% 60%",
  },
];
---

<Layout title={HOME.TITLE} description={HOME.DESCRIPTION}>
  <Container>
    <div class="mt-8 flex gap-12">
      <!-- Fixed Sidebar Navigation -->
      <nav class="animate hidden w-48 flex-shrink-0 lg:block">
        <div class="sticky top-36">
          <div class="flex flex-col gap-4">
            <a
              href="#about"
              data-nav-link="about"
              class="nav-link group relative text-sm font-semibold text-stone-700 transition-colors hover:text-stone-900 dark:text-stone-300 dark:hover:text-stone-100"
            >
              About
              <span
                class="nav-underline absolute -bottom-1 left-0 h-0.5 w-0 bg-stone-900 transition-all duration-300 dark:bg-stone-100"
              ></span>
            </a>
            <a
              href="#projects"
              data-nav-link="projects"
              class="nav-link group relative text-sm font-semibold text-stone-700 transition-colors hover:text-stone-900 dark:text-stone-300 dark:hover:text-stone-100"
            >
              Projects
              <span
                class="nav-underline absolute -bottom-1 left-0 h-0.5 w-0 bg-stone-900 transition-all duration-300 dark:bg-stone-100"
              ></span>
            </a>
            <a
              href="#experience"
              data-nav-link="experience"
              class="nav-link group relative text-sm font-semibold text-stone-700 transition-colors hover:text-stone-900 dark:text-stone-300 dark:hover:text-stone-100"
            >
              Experience
              <span
                class="nav-underline absolute -bottom-1 left-0 h-0.5 w-0 bg-stone-900 transition-all duration-300 dark:bg-stone-100"
              ></span>
            </a>
            <a
              href="#connect"
              data-nav-link="connect"
              class="nav-link group relative text-sm font-semibold text-stone-700 transition-colors hover:text-stone-900 dark:text-stone-300 dark:hover:text-stone-100"
            >
              Connect
              <span
                class="nav-underline absolute -bottom-1 left-0 h-0.5 w-0 bg-stone-900 transition-all duration-300 dark:bg-stone-100"
              ></span>
            </a>
          </div>
        </div>
      </nav>

      <!-- Main Content -->
      <aside data-pagefind-ignore class="min-w-0 flex-1">
        <!-- About / Hero Section -->
        <section id="about" class="animate mb-28 scroll-mt-36">
          <h1
            class="mb-3 font-mono text-sm font-medium uppercase tracking-[0.2em] text-blue-600 dark:text-blue-400"
          >
            Product Engineer
          </h1>
          <div
            class="mt-8 max-w-2xl space-y-4 text-lg leading-relaxed text-stone-700 dark:text-stone-300"
          >
           <p>
  I build frontend-first products with React and TypeScript, and the work
  I like most is the kind people open every day without thinking about it.
</p>
<p>
  At Prenda I worked on both the frontend and the backend of an edtech
  platform used by microschools, building education tools and student
  dashboards. I also automated a background check process that had been
  manual before that.
</p>
<p>
  Since then I've been building independently, mostly client work alongside
  my own products like Swatch Mill and Rocket Boogie.
</p>
          </div>
          <div class="mt-8">
            <h3
              class="mb-3 text-xs font-semibold uppercase tracking-wider text-stone-500 dark:text-stone-500"
            >
              Skills
            </h3>
            <div class="flex flex-wrap gap-2">
              {
                [
                  "JavaScript",
                  "TypeScript",
                  "HTML",
                  "CSS",
                  "React",
                  "Next.js",
                  "Astro",
                  "Node.js",
                  "PostgreSQL",
                  "AWS",
                  "Docker",
                  "Tailwind",
                  "Sanity",
                  "Git",
                  "GitHub Actions",
                  "RESTful APIs",
                  "CI/CD",
                  "Agile Development",
                  "AI-assisted development",
                  "Figma",
                  "Adobe Creative Suite",
                  "Illustration",
                ].map((skill) => (
                  <span class="rounded-full bg-stone-200 px-3 py-1 text-sm font-medium text-stone-700 dark:bg-stone-800 dark:text-stone-300">
                    {skill}
                  </span>
                ))
              }
            </div>
          </div>
        </section>

        <!-- Projects Section -->
        <section id="projects" class="animate mb-24 scroll-mt-36">
          <h2
            class="mb-2 text-3xl font-bold text-stone-900 dark:text-stone-100"
          >
            Projects
          </h2>
          <p class="mb-8 text-base text-stone-500 dark:text-stone-400">
            Things I've built and own end to end.
          </p>
          <div class="flex flex-col gap-5">
            {
              projects.map((project) => (
                <ExperienceCard {...project} cta={project.company} showPeriod={false} />
              ))
            }
          </div>
        </section>

        <!-- Experience Section -->
        <section id="experience" class="animate mb-24 scroll-mt-36">
          <h2
            class="mb-2 text-3xl font-bold text-stone-900 dark:text-stone-100"
          >
            Experience
          </h2>
          <p class="mb-8 text-base text-stone-500 dark:text-stone-400">
            Where I've worked, and what I shipped while I was there.
          </p>
          <div class="flex flex-col gap-5">
            {
              jobs.map((job) => (
                <ExperienceCard {...job} cta={job.company} />
              ))
            }
          </div>
        </section>

        <!-- Connect Section -->
        <section id="connect" class="animate mt-12 scroll-mt-36 space-y-4">
          <h2
            class="mb-4 text-2xl font-bold text-stone-900 dark:text-stone-100"
          >
            Connect
          </h2>

          <p class="mb-4 text-base leading-relaxed text-stone-700 dark:text-stone-300">
            Get in touch about frontend engineering, product work, or
            anything we might build together.
          </p>
          <p class="text-base font-semibold text-stone-900 dark:text-stone-100">
            <Link href={`mailto:${SITE.EMAIL}`} aria-label={`Email ${SITE.TITLE}`}>
              {SITE.EMAIL}
            </Link>
          </p>

          <ul class="not-prose flex flex-wrap gap-2">
            {
              SOCIALS.map((SOCIAL) => (
                <li class="flex gap-x-2 text-nowrap pb-4">
                  <Link
                    href={SOCIAL.HREF}
                    external
                    aria-label={`${SITE.TITLE} on ${SOCIAL.NAME}`}
                  >
                    {SOCIAL.NAME}
                  </Link>
                  {"/"}
                </li>
              ))
            }
            <li class="line-clamp-1">
              <Link href="/rss.xml" aria-label="Scott Lingner RSS feed">
                RSS
              </Link>
            </li>
          </ul>
        </section>
      </aside>
    </div>
  </Container>
</Layout>

<Pelican />

<style>
  html {
    scroll-behavior: smooth;
  }
</style>

<script is:inline>
  function initializePage() {
    const sections = document.querySelectorAll("section[id]");
    const navLinks = document.querySelectorAll("[data-nav-link]");

    function setActiveLink(activeId) {
      navLinks.forEach((link) => {
        const underline = link.querySelector(".nav-underline");
        if (link.getAttribute("data-nav-link") === activeId) {
          link.classList.add("text-stone-900", "dark:text-stone-100");
          link.classList.remove("text-stone-700", "dark:text-stone-300");
          if (underline) underline.style.width = "100%";
        } else {
          link.classList.remove("text-stone-900", "dark:text-stone-100");
          link.classList.add("text-stone-700", "dark:text-stone-300");
          if (underline) underline.style.width = "0";
        }
      });
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) setActiveLink(entry.target.id);
        });
      },
      { root: null, rootMargin: "-144px 0px -50% 0px", threshold: 0.1 }
    );

    sections.forEach((section) => observer.observe(section));
    if (sections.length > 0) setActiveLink(sections[0].id);

    const stickyNav = document.querySelector(".sticky.top-36");
    if (stickyNav) {
      stickyNav.style.transition = "padding-top 0.35s cubic-bezier(0.4,0,0.2,1)";
    }
    window.addEventListener("scroll", () => {
      if (stickyNav) {
        stickyNav.style.paddingTop = window.scrollY > 42 ? "50px" : "0";
      }

      // The last section is often too short to cross the observer's
      // "-50% 0px" bottom margin once the page hits max scroll, so it
      // never registers as intersecting on its own - force it active
      // once the user has scrolled to (or near) the bottom of the page.
      const atBottom =
        window.innerHeight + window.scrollY >= document.documentElement.scrollHeight - 2;
      if (atBottom && sections.length > 0) {
        setActiveLink(sections[sections.length - 1].id);
      }
    });

    navLinks.forEach((link) => {
      link.addEventListener("click", (e) => {
        e.preventDefault();
        const targetId = link.getAttribute("data-nav-link");
        const targetSection = document.getElementById(targetId);
        if (targetSection) {
          const headerEl = document.querySelector("header");
          const headerHeight = headerEl ? headerEl.getBoundingClientRect().height : 0;
          const targetPosition =
            targetSection.getBoundingClientRect().top + window.pageYOffset - (headerHeight + 16);
          window.scrollTo({ top: targetPosition, behavior: "smooth" });
        }
      });
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initializePage);
  } else {
    initializePage();
  }
</script>
