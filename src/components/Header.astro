---
import Container from "@components/Container.astro";
import Link from "@components/Link.astro";
import Pelican from "@components/Pelican.astro";
---

<header transition:persist class="bg-stone-100 dark:bg-stone-900">
  <Container>
    <div class="flex flex-wrap items-center gap-y-2">
      <Link href="/" underline={false} class="brand-mark">
        Scott Lingner
      </Link>

      <nav class="ml-auto mr-4 hidden items-center gap-6 md:flex">
        <Link
          href="/"
          underline={false}
          class="nav-link text-sm font-medium !text-stone-700 hover:!text-stone-900 dark:!text-stone-300 dark:hover:!text-stone-100"
        >
          Home
        </Link>
        <Link
          href="/about"
          underline={false}
          class="nav-link text-sm font-medium !text-stone-700 hover:!text-stone-900 dark:!text-stone-300 dark:hover:!text-stone-100"
        >
          About
        </Link>
      </nav>

      <button
        id="mobile-menu-button"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        class="menu-toggle ml-auto flex items-center justify-center rounded p-2 text-stone-700 hover:bg-stone-200/80 dark:text-stone-300 dark:hover:bg-stone-700/80 md:hidden"
      >
        <svg
          id="mobile-menu-icon"
          height="20"
          width="20"
          viewBox="0 0 16 16"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
        >
          <path class="bar bar-top" d="M2 4h12"></path>
          <path class="bar bar-mid" d="M2 8h12"></path>
          <path class="bar bar-bottom" d="M2 12h12"></path>
        </svg>
      </button>
    </div>

    <nav id="mobile-menu" class="mobile-menu hidden flex-col items-end md:hidden">
      <Link
        href="/"
        underline={false}
        class="nav-link mobile-nav-link !text-stone-700 dark:!text-stone-300"
      >
        Home
      </Link>
      <Link
        href="/about"
        underline={false}
        class="nav-link mobile-nav-link !text-stone-700 dark:!text-stone-300"
      >
        About
      </Link>
    </nav>

      <!-- Search button - Commented out
      <button
        id="magnifying-glass"
        aria-label="Search"
        class="flex items-center rounded border border-stone-300/50 bg-stone-200/80 px-3 py-2 text-xs transition-all duration-300 ease-in-out hover:bg-stone-300/80 hover:text-stone-900 dark:border-stone-600/50 dark:bg-stone-700/80 dark:hover:bg-stone-600/50 dark:hover:text-stone-100"
      >
        <svg
          height="16"
          stroke-linejoin="round"
          viewBox="0 0 16 16"
          width="16"
          style="color: currentcolor;"
          ><path
            fill-rule="evenodd"
            clip-rule="evenodd"
            d="M3.5 7C3.5 5.067 5.067 3.5 7 3.5C8.933 3.5 10.5 5.067 10.5 7C10.5 7.88461 10.1718 8.69256 9.63058 9.30876L9.30876 9.63058C8.69256 10.1718 7.88461 10.5 7 10.5C5.067 10.5 3.5 8.933 3.5 7ZM9.96544 11.0261C9.13578 11.6382 8.11014 12 7 12C4.23858 12 2 9.76142 2 7C2 4.23858 4.23858 2 7 2C9.76142 2 12 4.23858 12 7C12 8.11014 11.6382 9.13578 11.0261 9.96544L14.0303 12.9697L14.5607 13.5L13.5 14.5607L12.9697 14.0303L9.96544 11.0261Z"
            fill="currentColor"></path></svg
        >
        &nbsp;Search
      </button>
      -->
    </div>
  </Container>
</header>

<Pelican />

<script>
  function updateActiveNavLinks() {
    const currentPath = window.location.pathname;

    const navLinks = document.querySelectorAll(".nav-link");
    navLinks.forEach((link) => {
      link.classList.remove("active");
    });

    if (currentPath === "/") {
      const homeLink = document.querySelector('a[href="/"].nav-link');
      homeLink?.classList.add("active");
    } else if (currentPath === "/about") {
      const aboutLink = document.querySelector('a[href="/about"].nav-link');
      aboutLink?.classList.add("active");
    }
  }

  // Run on initial load
  updateActiveNavLinks();

  // Run on Astro page navigation
  document.addEventListener("astro:page-load", () => {
    updateActiveNavLinks();
  });

  function setupMobileMenu() {
    const menuButton = document.getElementById("mobile-menu-button");
    const menu = document.getElementById("mobile-menu");

    if (!menuButton || !menu) return;
    if (menuButton.dataset.menuInitialized) return;
    menuButton.dataset.menuInitialized = "true";

    const closeMenu = () => {
      menu.classList.remove("is-open");
      menuButton.classList.remove("is-open");
      menuButton.setAttribute("aria-expanded", "false");
      window.setTimeout(() => {
        if (!menu.classList.contains("is-open")) {
          menu.classList.add("hidden");
          menu.classList.remove("flex");
        }
      }, 250);
    };

    const openMenu = () => {
      menu.classList.remove("hidden");
      menu.classList.add("flex");
      requestAnimationFrame(() => {
        menu.classList.add("is-open");
        menuButton.classList.add("is-open");
        menuButton.setAttribute("aria-expanded", "true");
      });
    };

    menuButton.addEventListener("click", () => {
      const isOpen = menuButton.getAttribute("aria-expanded") === "true";
      isOpen ? closeMenu() : openMenu();
    });

    menu.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", closeMenu);
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") closeMenu();
    });
  }

  setupMobileMenu();

  document.addEventListener("astro:page-load", () => {
    setupMobileMenu();
  });
</script>

<style>
  .nav-link {
    position: relative;
    transition: all 0.3s ease;
    display: inline-block;
    vertical-align: baseline;
  }

  .nav-link::after {
    content: "";
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 2px;
    background-color: currentColor;
    transition: width 0.3s ease;
  }

  .nav-link:hover::after {
    width: 100%;
  }

  .nav-link.active::after {
    width: 100% !important;
  }

  /*
   * Wordmark replaces the old illustrated PNG logo with the site's real
   * name, using the same multi-brand gradient underline that ties the
   * homepage's experience cards together (Prenda mint, sky blue, Rocket
   * Boogie marigold/terracotta) as the one signature accent of the nav.
   */
  .brand-mark {
    position: relative;
    display: inline-block;
    font-family: theme("fontFamily.sans");
    font-size: 1.75rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: theme("colors.stone.900");
  }

  :global(html.dark) .brand-mark {
    color: theme("colors.stone.100");
  }

  .brand-mark::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -0.05em;
    height: 0.2em;
    background: linear-gradient(
      90deg,
      #5fb88a 0%,
      #3b82f6 25%,
      #e8a33d 50%,
      #c65d2e 75%,
      #5fb88a 100%
    );
    background-size: 200% 100%;
    background-position: 0% 0%;
    z-index: -1;
    border-radius: 2px;
    transition: background-position 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .brand-mark:hover::after {
    background-position: 100% 0%;
  }

  /* Mobile menu: echoes the wordmark's gradient underline as a signature accent */
  .bar {
    transform-box: view-box;
    transform-origin: 8px 8px;
    transition:
      transform 0.3s cubic-bezier(0.4, 0, 0.2, 1),
      opacity 0.2s ease;
  }

  .menu-toggle.is-open .bar-top {
    transform: rotate(45deg) translateY(4px);
  }

  .menu-toggle.is-open .bar-mid {
    opacity: 0;
  }

  .menu-toggle.is-open .bar-bottom {
    transform: rotate(-45deg) translateY(-4px);
  }

  .mobile-menu {
    position: relative;
    margin-top: 0.25rem;
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    padding-bottom: 0;
    transition:
      max-height 0.3s cubic-bezier(0.4, 0, 0.2, 1),
      opacity 0.25s ease;
  }

  .mobile-menu::before {
    content: "";
    display: block;
    height: 2px;
    margin-bottom: 0.5rem;
    border-radius: 2px;
    background: linear-gradient(
      90deg,
      #5fb88a 0%,
      #3b82f6 25%,
      #e8a33d 50%,
      #c65d2e 75%,
      #5fb88a 100%
    );
    background-size: 200% 100%;
    background-position: 0% 0%;
    transition: background-position 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .mobile-menu.is-open {
    max-height: 12rem;
    opacity: 1;
    padding-bottom: 1rem;
  }

  .mobile-menu.is-open::before {
    background-position: 100% 0%;
  }

  .mobile-nav-link {
    position: relative;
    display: block;
    padding: 0.625rem 1rem 0.625rem 0.25rem;
    font-size: 0.9375rem;
    font-weight: 500;
    text-align: right;
    opacity: 0;
    transform: translateX(12px);
    transition:
      opacity 0.3s ease,
      transform 0.3s ease,
      color 0.2s ease;
  }

  .mobile-nav-link::before {
    content: "";
    position: absolute;
    right: 0;
    top: 50%;
    width: 3px;
    height: 0.9em;
    transform: translateY(-50%) scaleY(0);
    transform-origin: center;
    border-radius: 2px;
    background: linear-gradient(180deg, #e8a33d, #3b82f6);
    transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .mobile-nav-link:hover::before,
  .mobile-nav-link.active::before {
    transform: translateY(-50%) scaleY(1);
  }

  .mobile-nav-link::after {
    display: none;
  }

  .mobile-menu.is-open .mobile-nav-link {
    opacity: 1;
    transform: translateX(0);
  }

  .mobile-menu.is-open .mobile-nav-link:nth-child(2) {
    transition-delay: 0.05s;
  }

  .mobile-menu.is-open .mobile-nav-link:nth-child(3) {
    transition-delay: 0.1s;
  }

  @media (prefers-reduced-motion: reduce) {
    .bar,
    .mobile-menu,
    .mobile-menu::before,
    .mobile-nav-link,
    .mobile-nav-link::before {
      transition: none !important;
    }
  }
</style>
