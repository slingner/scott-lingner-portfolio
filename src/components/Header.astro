      -->
    </div>
  </Container>
</header>

<Pelican />

<script>
  function updateActiveNavLinks() {
    const currentPath = window.location.pathname;

    const navLinks = document.querySelectorAll(".nav-link");
    navLinks.forEach((link) => {
      link.classList.remove("active");
    });

    if (currentPath === "/") {
      const homeLink = document.querySelector('a[href="/"].nav-link');
      homeLink?.classList.add("active");
    } else if (currentPath === "/about") {
      const aboutLink = document.querySelector('a[href="/about"].nav-link');
      aboutLink?.classList.add("active");
    }
  }

  // Run on initial load
  updateActiveNavLinks();

  // Run on Astro page navigation
  document.addEventListener("astro:page-load", () => {
    updateActiveNavLinks();
  });
</script>

<style>
  .nav-link {
    position: relative;
    transition: all 0.3s ease;
    display: inline-block;
    vertical-align: baseline;
  }

  .nav-link::after {
    content: "";
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 2px;
    background-color: currentColor;
    transition: width 0.3s ease;
  }

  .nav-link:hover::after {
    width: 100%;
  }

  .nav-link.active::after {
    width: 100% !important;
  }

  /*
   * Wordmark replaces the old illustrated PNG logo with the site's real
   * name, using the same multi-brand gradient underline that ties the
   * homepage's experience cards together (Prenda mint, sky blue, Rocket
   * Boogie marigold/terracotta) as the one signature accent of the nav.
   */
  .brand-mark {
    position: relative;
    display: inline-block;
    font-family: theme("fontFamily.sans");
    font-size: 1.75rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: theme("colors.stone.900");
  }

  :global(html.dark) .brand-mark {
    color: theme("colors.stone.100");
  }

  .brand-mark::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -0.05em;
    height: 0.2em;
    background: linear-gradient(
      90deg,
      #5fb88a 0%,
      #3b82f6 25%,
      #e8a33d 50%,
      #c65d2e 75%,
      #5fb88a 100%
    );
    background-size: 200% 100%;
    background-position: 0% 0%;
    z-index: -1;
    border-radius: 2px;
    transition: background-position 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .brand-mark:hover::after {
    background-position: 100% 0%;
  }
</style>
