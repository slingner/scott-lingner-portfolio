---
import ArrowIcon from "./ArrowIcon.astro";

type Props = {
  company: string;
  role: string;
  period: string;
  description: string;
  skills: string[];
  url: string;
  accent: string;
  image: string;
  imagePosition?: string;
  cta: string;
};

const { company, role, period, description, skills, url, accent, image, imagePosition, cta } =
  Astro.props;
---

<a
  href={url}
  data-accent={accent}
  class="exp-card group grid overflow-hidden rounded-xl border transition-all duration-300 sm:grid-cols-[minmax(0,1fr)_minmax(0,1fr)]"
>
  <div class="exp-panel relative z-10 flex flex-col justify-center gap-3 p-7">
    <span class="font-mono text-xs text-white/60">{period}</span>
    <h3 class="text-3xl font-extrabold leading-none tracking-tight text-white">
      {company}
    </h3>
    <p class="text-sm font-semibold uppercase tracking-wide text-white/80">
      {role}
    </p>
    <p class="max-w-sm text-sm leading-relaxed text-white/85">
      {description}
    </p>
    <div class="flex flex-wrap gap-1.5 pt-1">
      {
        skills.map((skill) => (
          <span class="rounded bg-white/15 px-2 py-1 text-xs font-medium text-white">
            {skill}
          </span>
        ))
      }
    </div>
    <span class="exp-cta mt-2 inline-flex w-fit items-center gap-1.5 text-sm font-bold text-white">
      {cta}
      <ArrowIcon class="size-[15px] transition-transform duration-300 group-hover:translate-x-1" />
    </span>
  </div>
  <div class="relative min-h-[14rem] overflow-hidden sm:min-h-0">
    <img
      src={image}
      alt=""
      aria-hidden="true"
      class="exp-photo absolute inset-0 h-full w-full object-cover transition-transform duration-500 ease-out group-hover:scale-105"
      style={`object-position: ${imagePosition ?? "center"};`}
      loading="lazy"
    />
  </div>
</a>

<style>
  /*
   * Accent colors come from the shared [data-accent] rules in
   * global.css, so a card's text panel and its page hero always match.
   * Keeping the text on a solid color (rather than over the photo)
   * means it stays readable regardless of what's in the image — the
   * photo lives on its own half of the card instead of behind text.
   */
  .exp-card {
    border-color: rgba(0, 0, 0, 0.1);
  }

  .exp-panel {
    background: linear-gradient(160deg, var(--accent), var(--accent-2));
  }

  .exp-cta {
    opacity: 0.85;
    transition: opacity 0.3s ease;
  }

  .exp-card:hover .exp-cta {
    opacity: 1;
  }

  .exp-card:hover {
    box-shadow: 0 12px 32px -12px var(--accent);
    transform: translateY(-3px);
  }

  @media (prefers-reduced-motion: reduce) {
    .exp-card,
    .exp-photo {
      transition: none !important;
    }
  }
</style>
